    "primo(X, Y) <= padre(P1, X) & tia(P1, Y) & hombre(X)\n",
    "prima(X, Y) <= padre(P1, X) & tio(P1, Y) & mujer(X)\n",
    "prima(X, Y) <= padre(P1, X) & tia(P1, Y) & mujer(X)\n",
    "antecesores(X, Y) <= padre(X, Y)\n",
    "antecesores(X, Y) <= padre(X, Z) & antecesores(Z, Y)\n",
    "\n",
    "# --- Corridas ---------------------------------------------------------------\n",
    "consultar(\"padre(X, Y)\", lambda: padre(X, Y))\n",
