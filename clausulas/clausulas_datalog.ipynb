    "# Instala pyDatalog si hiciera falta (descomentar si es necesario)\n",
    "# %pip install pyDatalog\n",
    "\n",
    "from pyDatalog import pyDatalog\n",
    "\n",
    "\n",
    "def consultar(nombre, expresion):\n",
    "    \"\"\"Imprime el resultado de una consulta, manejando el caso en que el\n",
    "    predicado no tenga ningun hecho ni regla asociada (pyDatalog lanza una\n",
    "    excepcion en ese caso, en vez de devolver una tabla vacia).\"\"\"\n",
    "    print(nombre)\n",
    "    try:\n",
    "        print(expresion())\n",
    "    except Exception:\n",
    "        print(\"(sin resultados: no hay hechos definidos para este predicado)\")\n",
    "    print()\n",
    "\n",
    "\n",
    "print(\"Libreria cargada correctamente.\")"
   ]
