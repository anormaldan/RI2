    "# Se reinicia el motor de Datalog para que los hechos de la Version A no se\n",
    "# mezclen con los de esta version.\n",
    "pyDatalog.clear()\n",
    "pyDatalog.create_terms(\n",
    "    'papa, mama, padre, abuelo, hombre, mujer, hermano, hermana, tio, tia, '\n",
    "    'primo, prima, antecesores, X, Y, Z, P1'\n",
    ")\n",
    "\n",
    "# --- Hechos: la familia original mas algunos familiares adicionales --------\n",
    "+ papa('Bruno', 'John')\n",
    "+ papa('John', 'Pedro')\n",
    "+ papa('Pedro', 'Luis')\n",
    "+ papa('Pedro', 'Pablo')\n",
    "+ papa('John', 'Ana')          # Ana es hermana de Pedro (hija de John)\n",
    "+ papa('Pedro', 'Lucia')       # Lucia es hermana de Luis y Pablo (hija de Pedro)\n",
    "\n",
    "+ mama('Rosa', 'John')\n",
    "+ mama('Elena', 'Pedro')\n",
    "+ mama('Elena', 'Ana')\n",
    "+ mama('Sofia', 'Luis')\n",
    "+ mama('Sofia', 'Pablo')\n",
    "+ mama('Sofia', 'Lucia')\n",
    "+ mama('Ana', 'Diego')         # Diego es hijo de Ana -> primo de Luis/Pablo/Lucia\n",
    "+ mama('Ana', 'Valeria')       # Valeria es hija de Ana -> prima de Luis/Pablo/Lucia\n",
    "\n",
    "+ hombre('Bruno')\n",
    "+ hombre('John')\n",
    "+ hombre('Pedro')\n",
    "+ hombre('Luis')\n",
    "+ hombre('Pablo')\n",
    "+ hombre('Diego')\n",
    "\n",
    "+ mujer('Rosa')\n",
    "+ mujer('Elena')\n",
    "+ mujer('Sofia')\n",
    "+ mujer('Ana')\n",
    "+ mujer('Lucia')\n",
    "+ mujer('Valeria')\n",
    "\n",
    "# --- Predicado auxiliar: padre = papa o mama --------------------------------\n",
    "padre(X, Y) <= papa(X, Y)\n",
    "padre(X, Y) <= mama(X, Y)\n",
    "\n",
    "# --- Reglas, ahora escritas una sola vez usando padre() ---------------------\n",
    "abuelo(X, Y) <= padre(X, Z) & padre(Z, Y)\n",
