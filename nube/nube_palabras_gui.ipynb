   "source": [
    "# Instala dependencias si hiciera falta (descomentar si es necesario)\n",
    "# %pip install wordcloud nltk matplotlib ipywidgets\n",
    "\n",
    "import os                                # rutas y creacion de carpetas de salida\n",
    "import re                                # limpieza de texto con expresiones regulares\n",
    "from collections import Counter          # conteo de frecuencias de palabras\n",
    "\n",
    "from wordcloud import WordCloud, STOPWORDS   # generacion de la nube de palabras\n",
    "import matplotlib.pyplot as plt          # renderizado de la nube como figura\n",
    "import nltk                              # stopwords en espanol/ingles\n",
    "from nltk.corpus import stopwords\n",
    "\n",
    "import ipywidgets as widgets             # componentes de la interfaz grafica (GUI)\n",
    "from IPython.display import display\n",
    "\n",
    "# Descarga de stopwords de NLTK (solo la primera vez; no vuelve a descargar si ya existen)\n",
    "nltk.download(\"stopwords\", quiet=True)\n",
    "\n",
    "print(\"Librerias cargadas correctamente.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Lógica de nube de palabras\n",
    "\n",
    "Funciones principales:\n",
    "\n",
    "- limpiar_texto(texto): convierte a minusculas y elimina caracteres no alfabeticos, dejando solo palabras en espanol/ingles.\n",
    "- obtener_stopwords(): combina las stopwords de NLTK (espanol e ingles) con las de la libreria wordcloud, para un filtrado mas completo.\n",
    "- contar_frecuencias(texto): tokeniza el texto limpio y cuenta cuantas veces aparece cada palabra, descartando stopwords y palabras muy cortas (menos de 3 letras).\n",
    "- generar_nube(frecuencias): construye la nube de palabras a partir de las frecuencias y devuelve la figura de matplotlib lista para mostrarse o guardarse.\n",
    "- procesar_texto(texto): funcion de alto nivel que encadena las tres anteriores; es el punto de entrada que usa la interfaz grafica."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Funciones de nube de palabras definidas.\n"
     ]
    }
   ],
   "source": [
    "OUTPUT_DIR = \"output\"\n",
    "\n",
    "\n",
    "def limpiar_texto(texto):\n",
    "    \"\"\"Convierte a minusculas y elimina caracteres no alfabeticos.\"\"\"\n",
    "\n",
    "    # Se conservan solo letras (incluyendo acentos y enye en espanol) y espacios.\n",
    "    texto = texto.lower()\n",
    "    texto = re.sub(r\"[^a-záéíóúüñ\\s]\", \" \", texto)\n",
    "    texto = re.sub(r\"\\s+\", \" \", texto).strip()\n",
    "\n",
    "    return texto\n",
    "\n",
    "\n",
    "def obtener_stopwords():\n",
    "    \"\"\"Combina las stopwords de NLTK (espanol e ingles) con las de wordcloud.\"\"\"\n",
    "\n",
    "    stops_es = set(stopwords.words(\"spanish\"))\n",
    "    stops_en = set(stopwords.words(\"english\"))\n",
    "    stops_wc = {w.lower() for w in STOPWORDS}\n",
    "\n",
    "    return stops_es | stops_en | stops_wc\n",
    "\n",
    "\n",
    "def contar_frecuencias(texto):\n",
    "    \"\"\"Cuenta cuantas veces aparece cada palabra, sin stopwords.\"\"\"\n",
    "\n",
    "    todas_stopwords = obtener_stopwords()\n",
    "\n",
    "    palabras = [\n",
    "        p for p in texto.split()\n",
    "        if len(p) >= 3 and p not in todas_stopwords\n",
    "    ]\n",
    "\n",
    "    return Counter(palabras)\n",
    "\n",
    "\n",
    "def generar_nube(frecuencias):\n",
    "    \"\"\"Genera la nube de palabras y devuelve la figura de matplotlib.\"\"\"\n",
    "\n",
    "    nube = WordCloud(\n",
    "        width=1000,\n",
    "        height=600,\n",
    "        background_color=\"black\",   # fondo negro para mayor contraste visual\n",
    "        max_words=60,               # toma las 60 palabras con mayor frecuencia; el resto se descarta\n",
    "        colormap=\"plasma\",\n",
    "        collocations=False,\n",
    "    ).generate_from_frequencies(dict(frecuencias))\n",
    "\n",
    "    fig = plt.figure(figsize=(12, 7))\n",
    "    plt.imshow(nube, interpolation=\"bilinear\")\n",
    "    plt.axis(\"off\")\n",
    "    plt.title(\"Nube de palabras\", fontsize=14)\n",
    "    plt.tight_layout()\n",
    "\n",
    "    return fig\n",
    "\n",
    "\n",
    "def procesar_texto(texto):\n",
    "    \"\"\"Funcion de alto nivel: limpia, cuenta y genera. Punto de entrada usado por la interfaz grafica.\"\"\"\n",
    "\n",
    "    texto_limpio = limpiar_texto(texto)\n",
    "    frecuencias = contar_frecuencias(texto_limpio)\n",
    "    fig = generar_nube(frecuencias)\n",
    "\n",
    "    return frecuencias, fig\n",
    "\n",
    "\n",
    "print(\"Funciones de nube de palabras definidas.\")"
   ]
  },
