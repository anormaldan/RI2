   "source": [
    "# --- Texto de ejemplo (si existe un archivo en esta carpeta) --------------\n",
    "TEXTO_EJEMPLO = \"\"\n",
    "NOMBRE_FUENTE = \"archivo_de_texto\"\n",
    "if os.path.exists(\"archivo_de_texto.txt\"):\n",
    "    with open(\"archivo_de_texto.txt\", encoding=\"utf-8\") as f:\n",
    "        TEXTO_EJEMPLO = f.read()\n",
    "\n",
    "# --- Area de texto ---------------------------------------------------------\n",
    "texto_input = widgets.Textarea(\n",
    "    value=TEXTO_EJEMPLO,\n",
    "    placeholder=\"Pega aqui el texto, o carga un archivo .txt con el boton de abajo\",\n",
    "    layout=widgets.Layout(width=\"700px\", height=\"180px\"),\n",
    ")\n",
    "texto_input.add_class(\"campo-texto-grande\")\n",
    "\n",
    "# --- Botones de accion ---------------------------------------------------\n",
    "carga_archivo = widgets.FileUpload(\n",
    "    description=\"Cargar .txt\",\n",
    "    accept=\".txt\",\n",
    "    multiple=False,\n",
    "    layout=widgets.Layout(width=\"220px\", height=\"50px\"),\n",
    ")\n",
    "carga_archivo.add_class(\"boton-grande\")\n",
    "\n",
    "boton_generar = widgets.Button(\n",
    "    description=\"Generar Nube\",\n",
    "    button_style=\"primary\",\n",
    "    icon=\"cloud\",\n",
    "    layout=widgets.Layout(width=\"220px\", height=\"50px\"),\n",
    ")\n",
    "boton_generar.add_class(\"boton-grande\")\n",
    "\n",
    "boton_exportar = widgets.Button(\n",
    "    description=\"Exportar PNG\",\n",
    "    button_style=\"success\",\n",
    "    icon=\"download\",\n",
    "    layout=widgets.Layout(width=\"220px\", height=\"50px\"),\n",
    ")\n",
    "boton_exportar.add_class(\"boton-grande\")\n",
    "\n",
    "# --- Areas de salida dentro de la GUI ------------------------------------\n",
    "resumen = widgets.HTML()          # resumen de totales y top de palabras\n",
    "mensaje_estado = widgets.HTML()   # mensajes de estado y errores\n",
    "area_nube = widgets.Output()      # aqui se dibuja la nube de palabras\n",
    "\n",
    "# Guarda el ultimo resultado en memoria para poder exportarlo a PNG\n",
    "# sin tener que volver a procesar el texto.\n",
    "ultimo_resultado = {\"fig\": None, \"frecuencias\": None}\n",
    "\n",
    "\n",
    "def al_cargar_archivo(change):\n",
    "    global NOMBRE_FUENTE\n",
    "    archivos = carga_archivo.value\n",
    "    if not archivos:\n",
    "        return\n",
    "    archivo = archivos[0] if isinstance(archivos, (list, tuple)) else list(archivos.values())[0]\n",
    "    NOMBRE_FUENTE = os.path.splitext(archivo[\"name\"])[0]\n",
    "    contenido = archivo[\"content\"].tobytes().decode(\"utf-8\", errors=\"ignore\")\n",
    "    texto_input.value = contenido\n",
    "    mensaje_estado.value = \"<span style=\\\"font-size:16px;\\\">Archivo cargado en el area de texto.</span>\"\n",
    "\n",
    "\n",
    "def renderizar_resultado(frecuencias):\n",
    "    \"\"\"Actualiza el resumen con el total de palabras y el top 10 mas frecuente.\"\"\"\n",
    "\n",
    "    total_unicas = len(frecuencias)\n",
    "    total_tokens = sum(frecuencias.values())\n",
    "\n",
    "    partes = []\n",
    "    partes.append(\"<div style=\\\"font-size:16px; margin-top:6px;\\\">\")\n",
    "    partes.append(f\"<b>Palabras unicas encontradas:</b> {total_unicas} &nbsp; \")\n",
    "    partes.append(f\"<b>Total de tokens:</b> {total_tokens}<br>\")\n",
    "    if frecuencias:\n",
    "        top10 = \", \".join(f\"{p} ({c})\" for p, c in frecuencias.most_common(10))\n",
    "        partes.append(f\"<b>Top 10:</b> {top10}\")\n",
    "    partes.append(\"</div>\")\n",
    "    resumen.value = \"\".join(partes)\n",
    "\n",
    "\n",
    "def al_hacer_click_generar(b):\n",
    "    \"\"\"Manejador del boton Generar Nube: valida el texto, procesa y muestra el resultado.\"\"\"\n",
    "\n",
    "    texto = texto_input.value.strip()\n",
    "    if not texto:\n",
    "        mensaje_estado.value = \"<span style=\\\"color:#b00; font-size:16px;\\\">Pega un texto o carga un archivo .txt.</span>\"\n",
    "        return\n",
    "\n",
    "    mensaje_estado.value = \"<span style=\\\"font-size:16px;\\\">Generando nube de palabras...</span>\"\n",
    "    try:\n",
    "        frecuencias, fig = procesar_texto(texto)\n",
    "    except Exception as e:\n",
    "        # Cualquier error inesperado se muestra en la interfaz sin interrumpir el notebook.\n",
    "        mensaje_estado.value = f\"<span style=\\\"color:#b00; font-size:16px;\\\">Error inesperado: {e}</span>\"\n",
    "        resumen.value = \"\"\n",
    "        area_nube.clear_output()\n",
    "        return\n",
    "\n",
    "    ultimo_resultado[\"fig\"] = fig\n",
    "    ultimo_resultado[\"frecuencias\"] = frecuencias\n",
    "\n",
    "    mensaje_estado.value = \"<span style=\\\"font-size:16px;\\\">Nube generada.</span>\"\n",
    "    renderizar_resultado(frecuencias)\n",
    "\n",
    "    area_nube.clear_output(wait=True)\n",
    "    with area_nube:\n",
    "        display(fig)\n",
    "    plt.close(fig)\n",
    "\n",
    "\n",
    "def al_hacer_click_exportar(b):\n",
    "    \"\"\"Manejador del boton Exportar PNG: guarda la ultima nube generada en disco.\"\"\"\n",
    "\n",
    "    fig = ultimo_resultado[\"fig\"]\n",
    "    if fig is None:\n",
    "        mensaje_estado.value = \"<span style=\\\"color:#b00; font-size:16px;\\\">Primero genera una nube antes de exportar.</span>\"\n",
    "        return\n",
    "    os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "    nombre = os.path.join(OUTPUT_DIR, f\"nube_{NOMBRE_FUENTE}.png\")    \n",
    "    fig.savefig(nombre, dpi=150)\n",
    "    mensaje_estado.value = f\"<span style=\\\"font-size:16px;\\\">Imagen exportada a: {nombre}</span>\"\n",
    "\n",
    "\n",
    "# Se conectan los widgets con sus respectivos manejadores de evento.\n",
    "carga_archivo.observe(al_cargar_archivo, names=\"value\")\n",
    "boton_generar.on_click(al_hacer_click_generar)\n",
    "boton_exportar.on_click(al_hacer_click_exportar)\n",
    "\n",
    "# --- Estilos CSS de la interfaz (tipografia mas grande) -------------------\n",
    "_css_interfaz = (\n",
    "    \"<style>\"\n",
    "    \".campo-texto-grande textarea { font-size: 15px !important; } \"\n",
    "    \".boton-grande { font-size: 16px !important; font-weight: bold; }\"\n",
    "    \"</style>\"\n",
    ")\n",
    "estilo_interfaz = widgets.HTML(_css_interfaz)\n",
    "\n",
    "_titulo_interfaz = (\n",
    "    \"<h2>Nube de Palabras</h2>\"\n",
    "    \"<p style=\\\"font-size:15px;\\\">Valido para cualquier texto: pegalo o carga un archivo .txt y presiona Generar Nube.</p>\"\n",
    ")\n",
    "\n",
    "# --- Composicion final de la interfaz (contenedor vertical) --------------\n",
    "interfaz = widgets.VBox(\n",
    "    [\n",
    "        widgets.HTML(_titulo_interfaz),\n",
    "        estilo_interfaz,\n",
    "        widgets.HBox([texto_input], layout=widgets.Layout(margin=\"0 0 10px 0\")),\n",
    "        widgets.HBox([carga_archivo, boton_generar, boton_exportar], layout=widgets.Layout(margin=\"0 0 15px 0\")),\n",
    "        mensaje_estado,\n",
    "        resumen,\n",
    "        area_nube,\n",
    "    ],\n",
    "    layout=widgets.Layout(padding=\"15px\", border=\"1px solid #ccc\", width=\"100%\"),\n",
    ")\n",
    "\n",
    "display(interfaz)\n",
    "\n",
    "# Carga inicial de ejemplo: si hay texto de ejemplo, genera la nube apenas se ejecuta la celda.\n",
    "if TEXTO_EJEMPLO:\n",
    "    al_hacer_click_generar(None)"
   ]
